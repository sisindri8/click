# Copy this file to .env and fill in your actual values
# cp .env.example .env
#
# NEVER commit .env to Git — it contains real API keys.
# .env is already in .gitignore.

# Required: YouTube Data API v3 key
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" on your project first
YOUTUBE_API_KEY=your-youtube-api-key-here

# Optional: Claude API key (only needed when mock modes are disabled)
# Get from: https://console.anthropic.com/settings/keys
# Leave as-is if you're running with mock modes enabled
CLAUDE_API_KEY=not-set
